<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <style>
        body {
            font-family: Arial, sans-serif;
            max-width: 600px;
            margin: 50px auto;
            padding: 20px;
            background-color: #f5f5f5;
        }
        h1 {
            color: #333;
        }
    </style>
</head>
<body>
    <div>
        <a href="/new">Create New Message</a>
    </div>
    <h1><%= title %></h1>
    <p>Welcome to your Express app with EJS!</p>
    
    <div class="messages">
        <% messages.forEach(message => { %>
            <div class="message" id="message-<%= messages.indexOf(message) %>">
                <strong><%= message.user %></strong>
                <p><%= message.text %></p>
                <small><%= message.date %></small>
                <a href="/message/<%= messages.indexOf(message) %>">View Details</a>
            </div>
        <% }); %>
    </div>
</body>
</html>
